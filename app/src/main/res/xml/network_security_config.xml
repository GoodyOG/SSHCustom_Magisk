<?xml version="1.0" encoding="utf-8"?>
<!-- The companion app talks to the Go daemon over loopback HTTP only.
     Cleartext is allowed exclusively for 127.0.0.1 / localhost; everything
     else uses the system default (TLS-only). The daemon binds to loopback
     by config, so there is no scenario where this opens a public listener. -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
