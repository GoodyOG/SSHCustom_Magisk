<?xml version="1.0" encoding="utf-8"?>
<!--
  SSHCustom v2 launcher foreground: nested concentric tunnel rings with a
  bottom-anchored signal pulse. Reads as both a tunnel (looking through
  the entrance, layers receding to a vanishing point) and a wave/signal
  metaphor. Stays legible at 48dp and in Android 13+ monochrome themed
  icons because every stroke is a flat path with no fills.

  ViewBox 108x108 leaves the standard 18dp safe-zone margin around the
  72dp content area expected by adaptive icons.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outermost ring -->
    <path
        android:strokeWidth="6"
        android:strokeColor="#FF8AB4F8"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M22,72 L54,30 L86,72" />

    <!-- Middle ring -->
    <path
        android:strokeWidth="5.5"
        android:strokeColor="#FFADC6FF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M34,70 L54,44 L74,70" />

    <!-- Inner ring -->
    <path
        android:strokeWidth="5"
        android:strokeColor="#FFDBE5FF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M44,68 L54,55 L64,68" />

    <!-- Signal pulse (anchor dot at vanishing point) -->
    <path
        android:fillColor="#FFADC6FF"
        android:pathData="M54,82m-4.5,0a4.5,4.5 0 1,0 9,0a4.5,4.5 0 1,0 -9,0" />

    <!-- Underline accent: subtle horizon line across the bottom safe zone -->
    <path
        android:strokeWidth="2.5"
        android:strokeColor="#FF5C7AB8"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M30,90 L78,90" />

</vector>
